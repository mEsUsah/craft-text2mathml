{% import '_includes/forms.twig' as forms %}

{{ forms.textField({
    first: true,
    instructions: 'Input - <a href="https://www.mathmlcentral.com/format.html" target="_blank">How to Format Your Input</a>',
    name: field.handle,
    value: input,
}) }}

<div class="field">
    <div class="instructions">
        <p >Output  - Updates after save</p>
    </div>
    <div style="width: 100%; font-size: 1.5rem; border-radius: 3px; padding: 1.5rem; overflow: auto; background: #345e34; color: white;">
        {{output|raw}}
    </div>
</div>